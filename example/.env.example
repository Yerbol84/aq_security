# AQ Security Example Stack - Environment Variables
# Copy this file to .env and fill in your values

# ============================================================================
# PostgreSQL Configuration
# ============================================================================
POSTGRES_PASSWORD=secure_password_change_me_in_production
POSTGRES_DB=aq_security
POSTGRES_USER=aq_security_user
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=change_me_in_production

# ============================================================================
# Auth Service Configuration
# ============================================================================
AUTH_SERVICE_PORT=8080
AUTH_JWT_SECRET=your_jwt_secret_minimum_32_characters_change_me_now
AUTH_DATA_SERVICE_URL=http://server_data:8090

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# Environment (development | production)
ENV=development

# ============================================================================
# OAuth Providers (Optional)
# ============================================================================

# Google OAuth
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# GitHub OAuth (TODO)
# Get credentials from: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_REDIRECT_URI=http://localhost:8080/auth/github/callback

# ============================================================================
# Data Layer Configuration
# ============================================================================
DATA_SERVICE_PORT=8090

# ============================================================================
# Resource Server Configuration (Client Example)
# ============================================================================
RESOURCE_SERVER_PORT=8081

# ============================================================================
# Test Credentials (Auto-seeded in development)
# ============================================================================
TEST_EMAIL=admin@test.com
TEST_PASSWORD=admin123
TEST_API_KEY=aq_test_1234567890abcdef

# ============================================================================
# Security Notes
# ============================================================================
# 1. NEVER commit .env file to git
# 2. Use strong passwords in production (min 32 chars)
# 3. Rotate JWT_SECRET regularly
# 4. Use different secrets for dev/staging/production
# 5. Store production secrets in secure vault (e.g., AWS Secrets Manager)
