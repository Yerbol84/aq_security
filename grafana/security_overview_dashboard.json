{
  "dashboard": {
    "title": "AQ Security - Security Overview",
    "tags": ["aq_security", "security", "overview"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "10s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Authentication Success Rate",
        "type": "stat",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "sum(rate(auth_attempts_total{success=\"true\"}[5m])) / sum(rate(auth_attempts_total[5m])) * 100",
            "legendFormat": "Success Rate %",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          },
          "orientation": "auto",
          "textMode": "value_and_name",
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 80, "color": "yellow"},
                {"value": 95, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Failed Auth Attempts (Last 5m)",
        "type": "stat",
        "gridPos": {
          "x": 6,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "sum(increase(auth_attempts_total{success=\"false\"}[5m]))",
            "legendFormat": "Failed Attempts",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          },
          "orientation": "auto",
          "textMode": "value_and_name",
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 10, "color": "yellow"},
                {"value": 50, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Rate Limit Blocks (Last 5m)",
        "type": "stat",
        "gridPos": {
          "x": 12,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "sum(increase(rate_limit_blocked_total[5m]))",
            "legendFormat": "Blocked Requests",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          },
          "orientation": "auto",
          "textMode": "value_and_name",
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 100, "color": "yellow"},
                {"value": 500, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Blocked IPs (Last 5m)",
        "type": "stat",
        "gridPos": {
          "x": 18,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "sum(increase(ip_blocked_total[5m]))",
            "legendFormat": "Blocked IPs",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          },
          "orientation": "auto",
          "textMode": "value_and_name",
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 5, "color": "yellow"},
                {"value": 20, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Authentication Attempts Over Time",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 4,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum(rate(auth_attempts_total{success=\"true\"}[5m])) by (method)",
            "legendFormat": "Success - {{method}}",
            "refId": "A"
          },
          {
            "expr": "sum(rate(auth_attempts_total{success=\"false\"}[5m])) by (method)",
            "legendFormat": "Failed - {{method}}",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Rate Limiting Activity",
        "type": "timeseries",
        "gridPos": {
          "x": 12,
          "y": 4,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum(rate(rate_limit_hits_total[5m])) by (strategy)",
            "legendFormat": "Hits - {{strategy}}",
            "refId": "A"
          },
          {
            "expr": "sum(rate(rate_limit_blocked_total[5m])) by (strategy)",
            "legendFormat": "Blocked - {{strategy}}",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Active Connections",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 12,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "active_connections",
            "legendFormat": "Active Connections",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 20
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 800, "color": "yellow"},
                {"value": 950, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 8,
        "title": "Connection Attempts",
        "type": "timeseries",
        "gridPos": {
          "x": 12,
          "y": 12,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum(rate(connection_attempts_total{allowed=\"true\"}[5m]))",
            "legendFormat": "Allowed",
            "refId": "A"
          },
          {
            "expr": "sum(rate(connection_attempts_total{allowed=\"false\"}[5m]))",
            "legendFormat": "Blocked",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 9,
        "title": "Token Operations",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 20,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum(rate(tokens_issued_total[5m])) by (type)",
            "legendFormat": "Issued - {{type}}",
            "refId": "A"
          },
          {
            "expr": "sum(rate(token_validations_total{valid=\"true\"}[5m]))",
            "legendFormat": "Valid Validations",
            "refId": "B"
          },
          {
            "expr": "sum(rate(token_validations_total{valid=\"false\"}[5m]))",
            "legendFormat": "Invalid Validations",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 10,
        "title": "Policy & Permission Checks",
        "type": "timeseries",
        "gridPos": {
          "x": 12,
          "y": 20,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum(rate(policy_evaluations_total{allowed=\"true\"}[5m]))",
            "legendFormat": "Policy Allowed",
            "refId": "A"
          },
          {
            "expr": "sum(rate(policy_evaluations_total{allowed=\"false\"}[5m]))",
            "legendFormat": "Policy Denied",
            "refId": "B"
          },
          {
            "expr": "sum(rate(permission_checks_total{granted=\"true\"}[5m]))",
            "legendFormat": "Permission Granted",
            "refId": "C"
          },
          {
            "expr": "sum(rate(permission_checks_total{granted=\"false\"}[5m]))",
            "legendFormat": "Permission Denied",
            "refId": "D"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 11,
        "title": "Top Blocked IPs by Reason",
        "type": "table",
        "gridPos": {
          "x": 0,
          "y": 28,
          "w": 24,
          "h": 6
        },
        "targets": [
          {
            "expr": "topk(10, sum(increase(ip_blocked_total[1h])) by (reason))",
            "legendFormat": "{{reason}}",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true
              },
              "renameByName": {
                "reason": "Reason",
                "Value": "Count"
              }
            }
          }
        ]
      }
    ]
  }
}
